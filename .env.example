# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=uma-senha-segura-aqui
POSTGRES_DB=ponto_db

# Admin User
ADMIN_NOME=<seu-nome-de-administrador-aqui>
ADMIN_EMAIL=<seu-email-aqui>
ADMIN_SENHA=<sua-senha-aqui>

# API Security
SECURITY_PEPPER=sua-pepper-secreta-aqui
JWT_SEGREDO=sua-chave-jwt-com-pelo-menos-256-bits-aqui

# Porta do app (padrão: 80)
APP_PORT=80
